# =============================================================================
# Management API Environment Configuration
# =============================================================================
# Copy this file to `.env` and update values as needed.
#
# NOTE: When running via Docker Compose, the environment variables in
# compose.yaml take precedence over this file. This .env file is primarily
# used when running the backend directly (e.g., for local debugging).
# =============================================================================

# Database
DATABASE_URL=sqlite:///./data/app.db

# Runtime boundary. Production rejects debug/test capabilities and weak secrets.
APP_ENV=development

# JWT
# Required for direct non-Compose startup. Generate a private random value with
# at least 32 characters. Standard Compose reads /run/secrets/JWT_SECRET_KEY,
# created locally through `./thesis.sh secrets`.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_ISSUER=twin2multicloud-management-api
JWT_AUDIENCE=twin2multicloud-client

# Durable external login transactions and abuse controls. Production requires
# a shared redis:// or rediss:// store. Leave provider credentials empty to
# disable that provider explicitly.
AUTH_TRANSACTION_TTL_SECONDS=600
AUTH_POLL_INTERVAL_MS=1000
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_STORAGE_URI=memory://
AUTH_LOGIN_RATE_LIMIT=20/minute
AUTH_EXCHANGE_RATE_LIMIT=120/minute

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# UIBK SAML. SAML_ENABLED=true requires every SP/IdP field below. Prefer
# /run/secrets files for certificates and private keys in production.
SAML_ENABLED=false
SAML_SP_ENTITY_ID=
SAML_ACS_URL=
SAML_SP_CERT=
SAML_SP_KEY=
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_CERT=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Server
HOST=0.0.0.0
PORT=5005
DEBUG=true
DEV_AUTH_ENABLED=true
DEV_AUTH_TOKEN=dev-token

# Credential endpoint protection. memory:// is only valid for a single-process
# development/test runtime. Production requires redis:// or rediss:// so every
# API replica shares the same counters.
CREDENTIAL_RATE_LIMIT_ENABLED=true
CREDENTIAL_RATE_LIMIT_STORAGE_URI=memory://
CREDENTIAL_WRITE_RATE_LIMIT=10/minute
CREDENTIAL_VALIDATION_RATE_LIMIT=6/minute
CREDENTIAL_BOOTSTRAP_RATE_LIMIT=5/minute

# Development serves plain HTTP. Production requires HTTPS and accepts
# X-Forwarded-Proto only from the explicitly listed direct proxy networks.
REQUIRE_HTTPS=false
TRUSTED_PROXY_CIDRS=

# Credential Encryption
# Required for direct non-Compose startup. This must be a URL-safe base64 key
# encoding exactly 32 random bytes and must remain stable for existing encrypted
# CloudConnections. Standard Compose reads /run/secrets/ENCRYPTION_KEY.
ENCRYPTION_KEY=

# =============================================================================
# External APIs
# =============================================================================
# These URLs connect to the Optimizer (2-twin2clouds) and Deployer (3-cloud-deployer).
#
# For Docker Compose: Use Docker internal hostnames (set in compose.yaml)
#   OPTIMIZER_URL=http://master-thesis-2twin2clouds-1:8000
#   DEPLOYER_URL=http://master-thesis-3cloud-deployer-1:8000
#
# For local development (running backend outside Docker): Use localhost
#   OPTIMIZER_URL=http://localhost:5003
#   DEPLOYER_URL=http://localhost:5004
#
# The values below are for Docker Compose (matching compose.yaml).
# Change to localhost:500X if running the backend directly.
# =============================================================================
OPTIMIZER_URL=http://master-thesis-2twin2clouds-1:8000
DEPLOYER_URL=http://master-thesis-3cloud-deployer-1:8000
DEPLOYMENT_PREFLIGHT_MAX_AGE_MINUTES=1440
